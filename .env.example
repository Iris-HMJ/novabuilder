# NovaBuilder Environment Variables

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=novabuilder

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m

# Encryption (32 bytes / 64 hex characters for AES-256-GCM)
ENCRYPTION_KEY=your-32-byte-hex-key-here-replace-it

# AI (Anthropic)
ANTHROPIC_API_KEY=

# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
